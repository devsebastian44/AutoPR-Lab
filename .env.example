# ==========================================
# AutoPR Lab - Configuración Local de Ejemplo
# ==========================================
# Copia este archivo a ".env" para configurar tu entorno local.
# NO introduzcas credenciales reales si vas a hacer commit.
# Este entorno permite la ejecución local mediante mocks (DRY_RUN).

# ------------------------------------------
# 1. Configuración Principal del Engine
# ------------------------------------------
# GitHub Token (Mockeable en DRY_RUN)
GITHUB_TOKEN=ghp_example_token_do_not_use_in_prod

# Repositorio objetivo (Ejemplo: devsebastian44/AutoPR-Lab)
GITHUB_REPOSITORY=tu_usuario/tu_repo

# Número de Pull Request a simular/escanear localmente
PR_NUMBER=123

# ------------------------------------------
# 2. Configuración de Comportamiento
# ------------------------------------------
# Nivel de logs: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Archivo de salida para el resultado del escaneo
SCAN_OUTPUT=scan_result.json

# ------------------------------------------
# 3. Modo Local Seguro (MUY IMPORTANTE)
# ------------------------------------------
# DRY_RUN: "true" asegura que no se enviará NINGUNA petición mutacional
# a la API real de GitHub. Útil para debugear, probar y contribuir
# sin riesgo de afectar repositorios reales.
DRY_RUN=true
